CLASS:PUBLIC

DESCRIPTION;LANGUAGE=en-US:This is a meeting that demonstrates VALARM functionality with multiple types of alarms:\nDisplay Alarm: Shows a popup 15 minutes before the meeting Email Alarm: Sends email reminders 1 hour before to attendees Audio Alarm: Plays a sound 5 minutes before the meeting The alarms are configured in the front matter and will be included in the generated iCalendar file.\nFront matter:\ntitle: "Meeting with Alarm Reminders" startDate: "2025-01-15T14:00:00" endDate: "2025-01-15T15:30:00" location: "Conference Room A" orga: "John Doe" orgaEmail: "john.doe@example.com" alarms: - action: "DISPLAY" trigger: duration: "-PT15M" description: text: "Meeting starts in 15 minutes" lang: "en" - action: "EMAIL" trigger: duration: "-PT1H" description: text: "Don't forget about the meeting in 1 hour" lang: "en" summary: text: "Meeting Reminder" lang: "en" attendee: - email: "john.doe@example.com" commonName: "John Doe" - email: "jane.smith@example.com" commonName: "Jane Smith" - action: "AUDIO" trigger: duration: "-PT5M" attach: uri: "file:///System/Library/Sounds/Glass.aiff" mediaType: "audio/aiff"
LAST-MODIFIED:20260430T135516Z
LOCATION;LANGUAGE=en-US:Conference Room A
STATUS:CONFIRMED
SUMMARY;LANGUAGE=en-US:Meeting with Alarm Reminders
TRANSP:OPAQUE
URL:https://finkregh.github.io/hugo-theme-component-ical/pr-preview/pr-42/events/event_11_with_alarm/

DTEND;VALUE=DATE-TIME;TZID=Europe/Zurich:20250115T153000
CONTACT;LANGUAGE=en-US:John Doe: john.doe@example.com
COLOR:crimson
BEGIN:VALARM
ACTION:DISPLAY
TRIGGER:-PT15M
DESCRIPTION;LANGUAGE=en:Meeting starts in 15 minutes
END:VALARM
BEGIN:VALARM
ACTION:EMAIL
TRIGGER:-PT1H
DESCRIPTION;LANGUAGE=en:Don't forget about the meeting in 1 hour
SUMMARY;LANGUAGE=en:Meeting Reminder
ATTENDEE;CN=John Doe:mailto:john.doe@example.com
ATTENDEE;CN=Jane Smith:mailto:jane.smith@example.com
END:VALARM
BEGIN:VALARM
ACTION:AUDIO
TRIGGER:-PT5M
ATTACH;FMTTYPE=audio/aiff:file:///System/Library/Sounds/Glass.aiff
END:VALARM
END:VEVENT
