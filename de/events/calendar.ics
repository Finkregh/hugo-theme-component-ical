DTSTART;VALUE=DATE-TIME:20240118T100000Z
CLASS:PUBLIC
DESCRIPTION;LANGUAGE=de:Monatliche Strategiebesprechung am dritten Donnerstag jedes Monats. Die Geschäftsleitung bespricht strategische Initiativen\, bewertet die Marktlage und passt die langfristige Planung anhand aktueller Leistungskennzahlen an.\nFront matter:\ntitle: Jeden dritten Donnerstag im Monat startDate: 2024-01-18T11:00:00+01:00 endDate: 2024-01-18T12:30:00+01:00 where: "Vorstandszimmer\, Obergeschoss" orga: "Strategiedirektor" orgaEmail: "strategy@example.org" # Jeden dritten Donnerstag im Monat recurrenceRule: freq: "MONTHLY" byDay: "TH" bySetPos: 3
LAST-MODIFIED:20260423T204334Z
LOCATION;LANGUAGE=de:
STATUS:CONFIRMED
SUMMARY;LANGUAGE=de:Jeden dritten Donnerstag im Monat
TRANSP:OPAQUE
URL:https://finkregh.github.io/hugo-theme-component-ical/de/events/event_10_third_thursday/

RRULE:FREQ=MONTHLY;INTERVAL=1;BYDAY=3TH
DTEND;VALUE=DATE-TIME:20240118T113000Z
CONTACT;LANGUAGE=de:Strategiedirektor: strategy@example.org
COLOR:crimson
END:VEVENT
