# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
# Unix-style newlines with a newline ending every file
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2

[*.ics]
insert_final_newline = false

[layouts/_partials/ical/prop_*.ics]
insert_final_newline = true

[layouts/_partials/ical/prop_{summary,classification,time_transparency}.ics]
insert_final_newline = false

[*.py]
indent_size = 4
