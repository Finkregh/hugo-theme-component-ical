{{- warnf "Template used: %s" templates.Current.Name -}}
{{- /* Check if any pages have valid event metadata before generating calendar */ -}}
{{- $hasValidEvents := false -}}
{{- range .Pages -}}
  {{- if .Params.startDate -}}
    {{- $hasValidEvents = true -}}
  {{- end -}}
{{- end -}}
{{- /* Only generate calendar if valid events exist */ -}}
{{- if $hasValidEvents -}}
BEGIN:VCALENDAR
{{- partial "header.ics" . -}}
{{- partial "timezone.ics" . }}
{{- range .Pages -}}
  {{- if .Params.startDate -}}
{{ partial "event.ics" . }}
  {{- end -}}
{{- end -}}
END:VCALENDAR
{{- end -}}