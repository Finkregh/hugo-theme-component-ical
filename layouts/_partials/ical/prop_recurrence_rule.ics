{{- /* Recurrence Rule

    RFC: https://tools.ietf.org/html/rfc5545#section-3.8.5.3

    Formal Specification:

       rrule      = "RRULE" rrulparam ":" recur CRLF

       rrulparam  = *(";" other-param)

       recur      = recur-rule-part *( ";" recur-rule-part )

       recur-rule-part = ( "FREQ"
                        / "UNTIL"
                        / "COUNT"
                        / "INTERVAL"
                        / "BYSECOND"
                        / "BYMINUTE"
                        / "BYHOUR"
                        / "BYDAY"
                        / "BYMONTHDAY"
                        / "BYYEARDAY"
                        / "BYWEEKNO"
                        / "BYMONTH"
                        / "BYSETPOS"
                        / "WKST" )
                        "=" recur-rule-value

    This implementation focuses on FREQ, INTERVAL, COUNT, UNTIL, BYDAY, BYMONTH, and BYSETPOS.

    Hugo Context Parameters:

      - .freq      : A string value ("YEARLY" or "MONTHLY")
      - .interval  : An integer value (default 1 if not specified)
      - .count     : An integer value (number of occurrences, mutually exclusive with until)
      - .until     : A date-time value (end date/time, mutually exclusive with count)
      - .byMonth   : An integer or array of integers (1-12 for months)
      - .byDay     : A string or array of strings ("SU", "MO", "TU", "WE", "TH", "FR", "SA")
      - .bySetPos  : An integer or array of integers (positive for nth occurrence, negative for last occurrences)
*/ -}}

{{- $parts := slice -}}

{{- /* FREQ is required */ -}}
{{- with .freq -}}
  {{- $parts = $parts | append (printf "FREQ=%s" (partial "ical/dt_freq.ics" .)) -}}
{{- else -}}
  {{- errorf "RRULE requires a freq value" -}}
{{- end -}}

{{- /* INTERVAL is required, always include it (RFC 5545 compliance) */ -}}
{{- $interval := 1 -}}
{{- with .interval -}}
  {{- $interval = . | int -}}
{{- end -}}
{{- $parts = $parts | append (printf "INTERVAL=%d" $interval) -}}

{{- /* COUNT and UNTIL are mutually exclusive per RFC 5545 Section 3.3.10 */ -}}
{{- if and .count .until -}}
  {{- errorf "RRULE cannot have both COUNT and UNTIL (RFC 5545 Section 3.3.10)" -}}
{{- end -}}

{{- /* COUNT: Number of occurrences (must be positive) */ -}}
{{- with .count -}}
  {{- if gt (. | int) 0 -}}
    {{- $parts = $parts | append (printf "COUNT=%s" (partial "ical/dt_integer.ics" .)) -}}
  {{- else -}}
    {{- errorf "prop_recurrence_rule.ics" "RRULE COUNT must be positive, got: %v" . -}}
  {{- end -}}
{{- end -}}

{{- /* UNTIL: End date/time for recurrence */ -}}
{{- with .until -}}
  {{- with dict `` `
    ` "dateTime" (. | time.AsTime).UTC `` `
    ` "isUTC" true `` `
    ` -}}
    {{- $parts = $parts | append (printf "UNTIL=%s" (partial "ical/dt_date_time.ics" .)) -}}
  {{- end -}}
{{- end -}}

{{- /* Handle BYDAY and BYSETPOS - convert BYDAY+BYSETPOS to ordinal BYDAY format for RFC 5545 compliance */ -}}
{{- $skipBySetPos := false -}}
{{- if and .byDay .bySetPos -}}
  {{- /* Convert BYDAY+BYSETPOS combination to ordinal BYDAY format */ -}}
  {{- $byDayValue := .byDay -}}
  {{- $bySetPosValue := .bySetPos -}}
  
  {{- /* Handle single bySetPos value */ -}}
  {{- if not (reflect.IsSlice $bySetPosValue) -}}
    {{- $bySetPosValue = slice $bySetPosValue -}}
  {{- end -}}
  
  {{- /* Handle single byDay value */ -}}
  {{- if not (reflect.IsSlice $byDayValue) -}}
    {{- $byDayValue = slice $byDayValue -}}
  {{- end -}}
  
  {{- /* Convert to ordinal format if we have single day and single position */ -}}
  {{- if and (eq (len $byDayValue) 1) (eq (len $bySetPosValue) 1) -}}
    {{- $day := index $byDayValue 0 -}}
    {{- $pos := index $bySetPosValue 0 -}}
    {{- $ordinalDay := printf "%d%s" $pos $day -}}
    {{- $parts = $parts | append (printf "BYDAY=%s" $ordinalDay) -}}
    {{- $skipBySetPos = true -}}
  {{- else -}}
    {{- /* Multiple days or positions - keep separate BYDAY and BYSETPOS */ -}}
    {{- $parts = $parts | append (printf "BYDAY=%s" (partial "ical/dt_weekday.ics" .byDay)) -}}
  {{- end -}}
{{- else if .byDay -}}
  {{- /* Only BYDAY without BYSETPOS */ -}}
  {{- $parts = $parts | append (printf "BYDAY=%s" (partial "ical/dt_weekday.ics" .byDay)) -}}
{{- end -}}

{{- /* BYMONTH */ -}}
{{- with .byMonth -}}
  {{- $parts = $parts | append (printf "BYMONTH=%s" (partial "ical/dt_month.ics" .)) -}}
{{- end -}}

{{- /* BYSETPOS - only include if not converted to ordinal BYDAY */ -}}
{{- if and .bySetPos (not $skipBySetPos) -}}
  {{- $parts = $parts | append (printf "BYSETPOS=%s" (partial "ical/dt_setpos.ics" .bySetPos)) -}}
{{- end -}}

RRULE:{{- delimit $parts ";" }}
