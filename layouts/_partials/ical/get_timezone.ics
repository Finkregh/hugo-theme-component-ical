{{- if or (eq hugo.Environment "development") (eq hugo.Environment "debug") }}{{ warnidf "debug-partial-used" "Partial used: %s" templates.Current.Name }}{{ end -}}
{{- /*
  Determine timezone from configuration with priority order:
  1. Page parameter: .Params.icaltimezone
  2. Site parameter: .Site.Params.ical.timezone
  3. Language-specific timeZone: .Site.Language.Params.timezone
  4. Global site parameter fallback: .Site.Params.timezone
  
  Returns the timezone string (e.g., "Europe/Zurich", "America/New_York")
  Fails build if no timezone is configured.
  
  NOTE: Hugo's timeZone config setting is not directly accessible in templates.
  Use site params instead: params.ical.timezone or params.timezone
*/ -}}
{{- $timezone := "" -}}
{{- with .Site.Params.timezone -}}
  {{- $timezone = . -}}
{{- end -}}
{{- with .Site.Language.Params.timezone -}}
  {{- $timezone = . -}}
{{- end -}}
{{- with .Site.Params.ical.timezone -}}
  {{- $timezone = . -}}
{{- end -}}
{{- with .Params.icaltimezone -}}
  {{- $timezone = . -}}
{{- end -}}

{{- /* Fail if no timezone configured */ -}}
{{- if not $timezone -}}
  {{- errorf "No timezone configured. Set params.ical.timezone in hugo.toml or icaltimezone in page frontmatter." -}}
{{- end -}}

{{- /* Return timezone string */ -}}
{{- $timezone -}}