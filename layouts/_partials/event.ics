{{- /* Adapt the dict here to fit your data model. See 'comp_event.ics' for available keys. */ -}}
{{- /* Multiline hack from: https://github.com/gohugoio/hugoDocs/issues/764#issuecomment-625711237 */ -}}
{{- if or (eq hugo.Environment "development") (eq hugo.Environment "debug") }}{{ warnidf "debug-partial-used" "Partial used: %s" templates.Current.Name }}{{ end -}}
{{- $timezone := partial "ical/get_timezone.ics" . -}}
{{- with dict `` `
  ` "description"  (dict "text" .Plain "lang" .Site.Language.Locale) `` `
  ` "summary"      (dict "text" .Title "lang" .Site.Language.Locale) `` `
  ` "eventStart"   (dict "dateTime" ((time.AsTime .Params.startDate $timezone) | time.In $timezone) "timeZoneID" $timezone) `` `
  ` "eventEnd"     (dict "dateTime" ((time.AsTime .Params.endDate $timezone) | time.In $timezone) "timeZoneID" $timezone) `` `
  ` "location"     (dict "text" (or .Params.where .Params.location) "lang" .Site.Language.Locale) `` `
  ` "url"          (.OutputFormats.Get "HTML").Permalink `` `
  ` "contact"      (cond (and .Params.orga .Params.orgaEmail) (dict "text" (printf "%s: %s" .Params.orga .Params.orgaEmail) "lang" .Site.Language.Locale) nil) `` `
  ` "color"        "crimson" `` `
  ` "status"       (cond (.Params.cancelled | default false) "CANCELLED" "CONFIRMED") `` `
  ` "uid"          .File.UniqueID `` `
  ` "timestamp"    .Date `` `
  ` "created"      .Date `` `
  ` "lastmod"      .Lastmod `` `
  ` "recurrenceRule" .Params.recurrenceRule `` `
  ` "_rruleTimezone" $timezone `` `
  ` -}}{{ partial "ical/comp_event.ics" . }}
{{ end -}}