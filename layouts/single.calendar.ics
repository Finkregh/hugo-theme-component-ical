{{- warnf "Template used: %s" templates.Current.Name -}}
{{- /* Check if current page has valid event metadata before generating calendar */ -}}
{{- if .Params.startDate -}}
BEGIN:VCALENDAR
{{- partial "header.ics" . -}}
{{- partial "timezone.ics" . }}
{{- partial "event.ics" . -}}
END:VCALENDAR
{{- end -}}