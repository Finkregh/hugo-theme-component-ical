{{- if or (eq hugo.Environment "development") (eq hugo.Environment "debug") }}{{ warnidf "debug-template-used" "Template used: %s" templates.Current.Name }}{{ end -}}
{{- /* Check if current page has valid event metadata before generating calendar */ -}}
{{- if .Params.startDate -}}
BEGIN:VCALENDAR
{{- partial "header.ics" . }}
{{ partial "timezone.ics" . }}
{{- partial "event.ics" . -}}
END:VCALENDAR
{{- end -}}